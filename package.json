{
  "name": "komerce-skill",
  "version": "1.0.0",
  "description": "AI Skills Registry CLI tool for managing AI assistant skills across multiple IDEs",
  "main": "dist/cli.js",
  "bin": {
    "komerce-skill": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:unit": "jest --testPathPattern='__tests__/unit'",
    "test:property": "jest --testPathPattern='__tests__/property'",
    "test:integration": "jest --testPathPattern='__tests__/integration'",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "skills",
    "registry",
    "cli",
    "kiro",
    "cursor",
    "copilot",
    "jetbrains",
    "antigravity",
    "windsurf",
    "claude-code",
    "cline",
    "gemini-cli",
    "augment",
    "aider"
  ],
  "author": "komerce-team",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "fast-check": "^3.23.2",
    "jest": "^29.7.0",
    "nock": "^13.5.6",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md"
  ]
}
